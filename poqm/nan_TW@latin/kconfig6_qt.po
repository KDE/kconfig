#: kreadconfig/kreadconfig.cpp:46 kreadconfig/kwriteconfig.cpp:25
msgctxt "main|"
msgid "Use <file> instead of global config"
msgstr "Iōng <file>, bái iōng tsuân-i̍k siat-tīng"

#: kreadconfig/kreadconfig.cpp:49 kreadconfig/kwriteconfig.cpp:28
msgctxt "main|"
msgid ""
"Group to look in. Use \"<default>\" for the root group, or use repeatedly "
"for nested groups."
msgstr ""
"Tī tsit-ê kûn-tsoo lāi-té tshuē. Iōng \"<default>\" lâi tshuē kin-kûn-tsoo, "
"á-sī tîng-ho̍k sú-iōng lâi tshuē nested ê kûn-tsoo."

#: kreadconfig/kreadconfig.cpp:52 kreadconfig/kwriteconfig.cpp:31
msgctxt "main|"
msgid "Key to look for"
msgstr "Ài tshuē ê kiān"

#: kreadconfig/kreadconfig.cpp:53
msgctxt "main|"
msgid "Default value"
msgstr "Ū-siat ti̍t"

#: kreadconfig/kreadconfig.cpp:54
msgctxt "main|"
msgid "Type of variable"
msgstr "Piàn-sòo ê luī-hîng"

#: kreadconfig/kreadconfig.cpp:55
msgctxt "main|"
msgid "Dump all entries"
msgstr "Tó-tshut sóo-ū ê hāng-bo̍k"

#: kreadconfig/kreadconfig.cpp:58
msgctxt "main|"
msgid ""
"Include globals; by default, the global config files are not read if a file "
"is specified"
msgstr ""
"Pau-kuat tsuân-i̍k siat-tīng; ū-siat sī tī ū tsí-tīng tóng-àn ê sî-tsūn bē "
"tho̍k-tshú tsuán-i̍k siat-tīng tóng-àn"

#: kreadconfig/kreadconfig.cpp:89 kreadconfig/kwriteconfig.cpp:71
msgctxt "main|"
msgid "Group name cannot be empty, use \"<default>\" for the root group"
msgstr ""
"Kûn-tsoo miâ bē-sái sī khang ê, ài tsí-tīng kin-kûn-tsoo tshiánn iōng "
"\"<default>\""

#: kreadconfig/kwriteconfig.cpp:34
msgctxt "main|"
msgid ""
"Type of variable. Use \"bool\" for a boolean, otherwise it is treated as a "
"string"
msgstr ""
"Piàn-sòo ê luī-hîng. Iōng \"bool\" lâi tsí-tīng pòo-lîm-ti̍t, kî-thann ê ti̍t "
"lóng sī tòng-tsò jī-tshng."

#: kreadconfig/kwriteconfig.cpp:36
msgctxt "main|"
msgid "Delete the designated key if enabled"
msgstr "Nā khé-iōng, thâi-tiāu tsí-tīng ê kiān"

#: kreadconfig/kwriteconfig.cpp:37
msgctxt "notify|"
msgid "Notify applications of the change"
msgstr "Kā ìng-iōng-tîng-sik thong-ti piàn-king"

#: kreadconfig/kwriteconfig.cpp:38
msgctxt "main|"
msgid "The value to write. Mandatory, on a shell use '' for empty"
msgstr ""
"Ài siá-ji̍p ê ti̍t. Su-iàu thê-kiong. Ài thê-kiong khang ê ti̍t, tī shell "
"tshiánn siá ''"
